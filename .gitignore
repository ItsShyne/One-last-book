# Ignorar absolutamente todo por defecto en la raíz
/*

# Excepciones: NO ignorar el archivo .gitignore ni la carpeta game
!/.gitignore
!/game/
# Ren'Py compiled files
*.rpyc
*.rpyb
*.pyc

# DDLC / Ren'Py archives
*.rpa

# Ren'Py engine folders (if copied)
/lib/
/renpy/

# Log files
errors.txt
log.txt
traceback.txt

# Ren'Py auto-generated directories
game/saves/
game/cache/

# OS-generated files & IDE settings
.DS_Store
Thumbs.db
.vscode/

